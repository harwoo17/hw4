<h1 class="mb-4"><%= @place["name"] %></h1>

<h2 class="mb-3">My Entries</h2>

<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <div class="card-body">

          <% if entry.image.attached? %>
            <%= image_tag entry.image, class: "img-fluid mb-3" %>
          <% end %>

          <h5 class="card-title"><%= entry["title"] %></h5>
          <h6 class="card-subtitle mb-2 text-muted"><%= entry["occurred_on"] %></h6>
          <p class="card-text"><%= entry["description"] %></p>

        </div>
      </div>
    </div>
  <% end %>
</div>

<% if session["user_id"] %>
  <p>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Entry</a>
  </p>
<% end %>

<p>
  <a href="/places" class="btn btn-outline-secondary">Back to All Places</a>
</p>