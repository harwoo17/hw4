<!DOCTYPE html>
<html>
  <head>
    <title>Tacostagram</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font (optional but fun) -->
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600&display=swap" rel="stylesheet">

    <style>
      body {
        font-family: 'Fredoka', sans-serif;
      }

      .navbar-custom {
        background: linear-gradient(90deg, #006847, #ffffff, #ce1126);
      }

      .navbar-brand {
        font-weight: 600;
        font-size: 1.5rem;
      }

      .taco {
        font-size: 1.5rem;
        margin-right: 6px;
      }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-light navbar-custom mb-4 border-bottom">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="/places">
          <span class="taco">🌮</span>
          Tacostagram
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a href="/places" class="nav-link fw-bold">Home</a>
            </li>
          </ul>

          <div class="d-flex align-items-center gap-2">
            <% if session["user_id"] %>
              <% user = User.find_by(id: session["user_id"]) %>
              <% if user %>
                <span class="fw-bold"><%= user.username %></span>
              <% end %>
              <a href="/logout" class="btn btn-outline-dark">Logout</a>
            <% else %>
              <a href="/login" class="btn btn-outline-dark">Login</a>
              <a href="/users/new" class="btn btn-danger">Signup</a>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <div class="container">
      <% if flash["notice"] %>
        <div class="alert alert-info">
          <%= flash["notice"] %>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>